# ──────────────────────────────────────────────
#  Configuración de entorno (copiar a .env)
# ──────────────────────────────────────────────

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── Base de datos: SQL Server ──
# Formato Prisma para sqlserver:
#   sqlserver://HOST:PORT;database=DB;user=USER;password=PASS;encrypt=true;trustServerCertificate=true
# Nota: el contenedor Docker publica SQL Server en el puerto 14330 del host
# (para no chocar con un SQL Server local que ocupa 1433 y 1434).
DATABASE_URL="sqlserver://localhost:14330;database=tickets;user=sa;password=Your_Strong_Pass123;encrypt=true;trustServerCertificate=true"

# ── Redis (colas BullMQ + cache) ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Autenticación JWT (los secretos deben tener >= 32 caracteres) ──
JWT_ACCESS_SECRET=genera-un-secreto-largo-y-aleatorio-de-32-o-mas
JWT_REFRESH_SECRET=otro-secreto-largo-y-aleatorio-distinto-de-32+
JWT_ACCESS_TTL=30m
JWT_REFRESH_TTL=7d

# ── CORS: orígenes permitidos (coma-separados). '*' solo en desarrollo ──
CORS_ORIGINS=*

# ── Reglas de negocio: SLA / reasignación ──
# Tiempo límite (en minutos) sin actividad antes de reasignar automáticamente
TICKET_SLA_MINUTES=60
# Intervalo (en minutos) del job de barrido de respaldo
REASSIGNMENT_SWEEP_INTERVAL_MINUTES=5
# Máximo de reasignaciones automáticas antes de escalar a supervisor
MAX_AUTO_REASSIGNMENTS=3
